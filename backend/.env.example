GROQ_API_KEY=your-groq-api-key
FRONTEND_URL=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
FLASK_DEBUG=false

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-secret
REQUIRE_EMAIL_VERIFICATION=false
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:5000/auth/oauth/github/callback

# Email (optional — links print to console when SMTP is unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@studybuddy.local

# Rate limiting
RATELIMIT_STORAGE_URI=memory://

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=studybuddy
DB_USER=studybuddy_user
DB_PASSWORD=your-mysql-password

